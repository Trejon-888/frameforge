{
  "name": "@frameforge/core",
  "version": "0.1.0",
  "description": "FrameForge rendering engine — deterministic browser-to-video pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "frameforge": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
