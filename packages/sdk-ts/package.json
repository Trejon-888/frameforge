    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "video",
    "animation",
    "scene-builder",
    "programmatic-video",
    "motion-graphics",
    "frameforge",
    "typescript-sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trejon-888/frameforge.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/Trejon-888/frameforge",
  "publishConfig": {
    "access": "public"
  }
