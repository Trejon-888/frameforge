{
  "name": "@frameforge/sdk",
  "version": "0.2.0",
  "description": "FrameForge TypeScript SDK — programmatic scene authoring",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
