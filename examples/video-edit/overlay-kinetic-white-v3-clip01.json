    "html": "<div class=\"cls-__ID__-w\"><canvas width=\"1080\" height=\"1920\" style=\"position:absolute;top:0;left:0;width:1080px;height:1920px;\"></canvas></div>",
    "initJs": "var c=el.querySelector('canvas'),ctx=c.getContext('2d'),W=1080,H=1920,N=26,nodes=[],conns=[],MAX=270;for(var i=0;i<N;i++){nodes.push({x:80+Math.random()*(W-160),y:80+Math.random()*(H-160),vx:(Math.random()-0.5)*0.35,vy:(Math.random()-0.5)*0.35});}for(var a=0;a<N;a++){for(var b=a+1;b<N;b++){var dx=nodes[a].x-nodes[b].x,dy=nodes[a].y-nodes[b].y;if(Math.sqrt(dx*dx+dy*dy)<MAX){conns.push({a:a,b:b,t:Math.random(),s:0.003+Math.random()*0.003});}}}function tick(){ctx.clearRect(0,0,W,H);nodes.forEach(function(n){n.x+=n.vx;n.y+=n.vy;if(n.x<80||n.x>W-80)n.vx*=-1;if(n.y<80||n.y>H-80)n.vy*=-1;});conns.forEach(function(conn){var A=nodes[conn.a],B=nodes[conn.b];var dx=B.x-A.x,dy=B.y-A.y;var d=Math.sqrt(dx*dx+dy*dy);if(d>MAX)return;var f=1-d/MAX;ctx.beginPath();ctx.moveTo(A.x,A.y);ctx.lineTo(B.x,B.y);ctx.strokeStyle='rgba(255,77,0,'+(f*0.09).toFixed(3)+')';ctx.lineWidth=1;ctx.stroke();conn.t+=conn.s;if(conn.t>1)conn.t=0;var px=A.x+dx*conn.t,py=A.y+dy*conn.t;ctx.beginPath();ctx.arc(px,py,2.5,0,6.28);ctx.fillStyle='rgba(255,77,0,'+(f*0.55).toFixed(3)+')';ctx.fill();});nodes.forEach(function(n){ctx.beginPath();ctx.arc(n.x,n.y,3,0,6.28);ctx.fillStyle='rgba(255,77,0,0.28)';ctx.fill();});requestAnimationFrame(tick);}requestAnimationFrame(tick);el._tl=gsap.timeline({paused:true}).fromTo(c,{opacity:0},{opacity:1,duration:0.5,ease:'power2.out'}).to({},{duration:11.1}).to(c,{opacity:0,duration:0.35,ease:'power2.in'});"
