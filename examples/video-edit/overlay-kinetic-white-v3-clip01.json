    "initJs": "var steps=el.querySelector('.cls-__ID__-steps');var phase2=el.querySelector('.cls-__ID__-phase2');var stepEls=el.querySelectorAll('.cls-__ID__-step,.cls-__ID__-arr');el._tl=gsap.timeline({paused:true}).fromTo(steps,{y:-100,opacity:0},{y:0,opacity:1,duration:0.32,ease:'power4.out'}).fromTo(stepEls,{opacity:0,x:-20},{opacity:1,x:0,duration:0.2,ease:'power3.out',stagger:0.3},'>+0.15').to({},{duration:5.0}).fromTo(phase2,{y:100,opacity:0},{y:0,opacity:1,duration:0.35,ease:'power4.out'}).to({},{duration:4.5}).to(steps,{opacity:0,duration:0.35,ease:'power2.in'}).to(phase2,{opacity:0,duration:0.35,ease:'power2.in'},'<');"
