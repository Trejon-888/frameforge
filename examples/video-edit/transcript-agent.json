  "phrases": [
    {
      "startSec": 0.031,
      "endSec": 2.718,
      "startMs": 31,
      "endMs": 2718,
      "text": "Little pause in the video before we go into showing the next thing."
    },
    {
      "startSec": 3.02,
      "endSec": 3.261,
      "startMs": 3020,
      "endMs": 3261,
      "text": "I mean,"
    },
    {
      "startSec": 3.301,
      "endSec": 5.607,
      "startMs": 3301,
      "endMs": 5607,
      "text": "you know that by the end of this video,"
    },
    {
      "startSec": 5.647,
      "endSec": 10.542,
      "startMs": 5647,
      "endMs": 10542,
      "text": "you will be able to create all of your content from one conversation with Cloud Code."
    },
    {
      "startSec": 10.704,
      "endSec": 13.01,
      "startMs": 10704,
      "endMs": 13010,
      "text": "But here's what I realized building this."
    },
    {
      "startSec": 13.074,
      "endSec": 13.355,
      "startMs": 13074,
      "endMs": 13355,
      "text": "I mean,"
    },
    {
      "startSec": 13.396,
      "endSec": 16.9,
      "startMs": 13396,
      "endMs": 16900,
      "text": "the content side is only half of the system."
    },
    {
      "startSec": 17.001,
      "endSec": 23.413,
      "startMs": 17001,
      "endMs": 23413,
      "text": "Because what's the point of creating all of this content if you don't have an actual pipeline bringing you clients?"
    },
    {
      "startSec": 23.753,
      "endSec": 26.297,
      "startMs": 23753,
      "endMs": 26297,
      "text": "That's the reason we built the iX system,"
    },
    {
      "startSec": 26.557,
      "endSec": 27.239,
      "startMs": 26557,
      "endMs": 27239,
      "text": "the other half."
    },
    {
      "startSec": 27.539,
      "endSec": 32.368,
      "startMs": 27539,
      "endMs": 32368,
      "text": "This is an AI client acquisition system that allows you to find your target buyer,"
    },
    {
      "startSec": 32.648,
      "endSec": 34.932,
      "startMs": 32648,
      "endMs": 34932,
      "text": "writes your entire outreach copy,"
    },
    {
      "startSec": 34.911,
      "endSec": 44.536,
      "startMs": 34911,
      "endMs": 44536,
      "text": "It has AI agents in the back and handling the entire conversations and books appointments directly into your calendar without you touching anything."
    },
    {
      "startSec": 44.798,
      "endSec": 51.996,
      "startMs": 44798,
      "endMs": 51996,
      "text": "And this is the exact same system that has been used by private equity firms managing over $4 billion in assets,"
    },
    {
      "startSec": 52.677,
      "endSec": 53.621,
      "startMs": 52677,
      "endMs": 53621,
      "text": "M&A advisories,"
    },
    {
      "startSec": 54.021,
      "endSec": 57.932,
      "startMs": 54021,
      "endMs": 57932,
      "text": "and 20 plus of our partners across our network."
    }
  ],
