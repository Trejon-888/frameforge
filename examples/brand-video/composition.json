{
  "version": "1.0",
  "name": "frameforge-brand",

  "canvas": {
    "width": 1920,
    "height": 1080,
    "fps": 30
  },

  "scenes": [
    {
      "entry": "./scene1-logo.html",
      "duration": 5,
      "background": "#0a0a0a",
      "transition": { "type": "fadeblack", "duration": 0.8 }
    },
    {
      "entry": "./scene2-power.html",
      "duration": 5,
      "background": "#0a0a0a",
      "transition": { "type": "fadeblack", "duration": 0.8 }
    },
    {
      "entry": "./scene3-cta.html",
      "duration": 5,
      "background": "#0a0a0a"
    }
  ],

  "render": {
    "codec": "h264",
    "quality": "high",
    "pixelFormat": "yuv420p",
    "output": "./output/frameforge-brand.mp4"
  }
}
